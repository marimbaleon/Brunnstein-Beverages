# Copy to .env (gitignored) and fill in.

PYTHONPATH=.
DSQL_CLUSTER_ID=your-cluster-id
AWS_REGION=eu-central-1
AWS_PROFILE=brunnstein
S3_INVOICES_BUCKET=brunnstein-invoices-<account-id>
BEDROCK_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# MLflow tracking backend. Default is a local SQLite file (mlflow.db),
# gitignored. Override to point at a remote tracking server if you have one.
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
